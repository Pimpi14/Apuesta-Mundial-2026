<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>⚽ Quiniela Mundial 2026 - Completa</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        :root{
            --bg:#0a0f1e; --bg2:#111827; --card:#161d2e;
            --border:#2a3650; --accent:#00d4aa; --accent2:#f7c948;
            --red:#e84545; --green:#1db97a; --blue:#3b82f6;
            --text:#f0f4ff; --text2:#8b9bb4;
        }
        body{background:var(--bg);color:var(--text);font-family:'Segoe UI',system-ui,sans-serif;padding:16px}
        .container{max-width:1400px;margin:0 auto}
        .header{text-align:center;margin-bottom:20px}
        .header h1{font-size:28px}
        .header h1 span{color:var(--accent)}
        .tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;background:var(--bg);padding:8px 0;position:sticky;top:0;z-index:100}
        .tab{background:var(--card);border:1px solid var(--border);padding:8px 14px;border-radius:30px;cursor:pointer;font-size:13px;color:var(--text2)}
        .tab.active{background:var(--accent);color:#000;border-color:var(--accent);font-weight:600}
        .panel{display:none}
        .panel.active{display:block}
        .card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:16px}
        .card-title{font-size:18px;font-weight:700;color:var(--accent2);margin-bottom:12px}
        .btn{background:var(--accent);border:none;padding:12px 20px;border-radius:30px;font-weight:700;cursor:pointer;width:100%;font-size:14px;margin-top:8px;color:#000}
        .btn-danger{background:var(--red);color:white}
        .btn-secondary{background:var(--bg2);border:1px solid var(--border);color:var(--text)}
        .btn-blue{background:var(--blue);color:white}
        .btn-small{background:var(--accent);border:none;padding:6px 12px;border-radius:20px;font-weight:600;cursor:pointer;font-size:11px;color:#000}
        .jugador-selector{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;background:var(--card);padding:12px;border-radius:16px;align-items:center}
        .jugador-btn{background:transparent;border:1px solid var(--border);padding:8px 16px;border-radius:30px;cursor:pointer;font-size:13px;color:var(--text2)}
        .jugador-btn.active{background:var(--accent);color:#000;border-color:var(--accent);font-weight:600}
        .grupo-titulo{font-size:16px;font-weight:700;color:var(--accent2);margin:16px 0 8px;padding-left:8px}
        .partido{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
        .equipos{font-size:13px;flex:2}
        .botones{display:flex;gap:6px}
        .apuesta-btn{padding:4px 12px;border-radius:20px;border:1px solid var(--border);background:transparent;cursor:pointer;font-size:12px;color:var(--text2)}
        .apuesta-btn.selected-1{background:rgba(0,212,170,0.2);border-color:var(--accent);color:var(--accent)}
        .apuesta-btn.selected-x{background:rgba(139,155,180,0.2);border-color:#8b9bb4;color:#c0cce0}
        .apuesta-btn.selected-2{background:rgba(232,69,69,0.2);border-color:var(--red);color:#ff8080}
        .apuesta-btn:disabled{opacity:0.5;cursor:not-allowed}
        .resultado-real{background:rgba(59,130,246,0.15);border:1px solid var(--blue);padding:4px 8px;border-radius:12px;font-size:11px;color:var(--blue);min-width:60px;text-align:center}
        .grid-2{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px}
        .grid-3{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px}
        .chk-label{display:block;padding:6px 0;cursor:pointer;color:var(--text2)}
        .admin-input{width:100%;padding:10px;margin:5px 0;border-radius:8px;border:1px solid var(--border);background:var(--bg2);color:var(--text)}
        .ranking-table{width:100%;border-collapse:collapse}
        .ranking-table th,.ranking-table td{padding:10px;text-align:left;border-bottom:1px solid var(--border);color:var(--text)}
        .pts-badge{background:rgba(0,212,170,0.2);padding:4px 10px;border-radius:20px;color:var(--accent);font-weight:700}
        .badge{font-size:11px;padding:2px 8px;border-radius:12px}
        .badge-lock{background:rgba(247,201,72,0.2);color:var(--accent2)}
        .badge-import{background:rgba(29,185,122,0.2);color:var(--green)}
        small{color:var(--text2);font-size:11px}
        .file-input{background:var(--bg2);border:1px solid var(--border);padding:12px;border-radius:12px;width:100%;margin-top:10px;color:var(--text)}
        .flex-row{display:flex;gap:12px;flex-wrap:wrap}
        .puntaje-vivo{background:rgba(0,212,170,0.1);border-radius:12px;padding:8px 16px;text-align:center;margin-bottom:16px;color:var(--text)}
        .puntaje-vivo span{font-size:28px;font-weight:700;color:var(--accent)}
        .clasif-grupo{display:flex;justify-content:space-between;align-items:center;padding:8px;border-bottom:1px solid var(--border)}
        .clasif-pos{font-weight:700;color:var(--accent2);width:60px}
        .clasif-equipos{flex:1;color:var(--text)}
        
        /* Estilos para selectores */
        .resultado-select {
            background: var(--bg2);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px 10px;
            color: var(--text);
            font-size: 13px;
            width: 100%;
            margin-top: 6px;
            cursor: pointer;
        }
        .resultado-select option {
            background: var(--bg2);
            color: var(--text);
            padding: 8px;
        }
        .resultado-select:focus {
            outline: none;
            border-color: var(--accent);
        }
        
        .partido-item {
            margin: 10px 0;
            padding: 10px;
            background: var(--bg2);
            border-radius: 10px;
            border-left: 3px solid var(--accent);
        }
        .partido-equipos {
            font-weight: 600;
            margin-bottom: 6px;
            color: var(--text);
        }
        
        /* Estilos para la tabla de puntuación */
        .puntuacion-tabla {
            width: 100%;
            border-collapse: collapse;
        }
        .puntuacion-tabla th {
            background: rgba(0,212,170,0.15);
            padding: 12px;
            text-align: left;
            color: var(--accent);
            font-weight: 700;
        }
        .puntuacion-tabla td {
            padding: 10px 12px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }
        .puntuacion-tabla tr:hover td {
            background: rgba(255,255,255,0.02);
        }
        .punto-destacado {
            color: var(--accent);
            font-weight: 700;
            font-size: 16px;
        }
        .info-box {
            background: rgba(0,212,170,0.05);
            border-left: 4px solid var(--accent);
            padding: 12px 16px;
            border-radius: 8px;
            margin: 12px 0;
        }
        
        @media(max-width:600px){
            .partido{flex-direction:column;align-items:flex-start;gap:8px}
            .botones{width:100%}
            .apuesta-btn{flex:1;text-align:center}
            .grid-2,.grid-3{grid-template-columns:1fr}
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>⚽ MUNDIAL <span>2026</span></h1>
        <p>Quiniela de amigos · Resultados en tiempo real</p>
    </div>

    <div class="tabs">
        <button class="tab active" onclick="mostrarPanel('jugadores',this)">👥 Jugadores</button>
        <button class="tab" onclick="mostrarPanel('apuestas',this)">📝 Mis Apuestas</button>
        <button class="tab" onclick="mostrarPanel('resultados',this)">🎯 Resultados en vivo</button>
        <button class="tab" onclick="mostrarPanel('puntuacion',this)">📋 Sistema de Puntuación</button>
        <button class="tab" onclick="mostrarPanel('admin',this)">🔧 Admin</button>
        <button class="tab" onclick="mostrarPanel('ranking',this)">📊 Ranking</button>
    </div>

    <!-- PANEL JUGADORES -->
    <div id="panel-jugadores" class="panel active">
        <div class="card">
            <div class="card-title">👥 Gestión de jugadores</div>
            <div class="flex-row">
                <input type="text" id="nuevoJugadorInput" class="admin-input" placeholder="Nombre del amigo" style="flex:2">
                <button class="btn-small" onclick="agregarJugador()" style="background:var(--accent);padding:10px 20px">➕ Añadir</button>
            </div>
        </div>
        <div id="listaJugadores"></div>
        <div class="card">
            <div class="card-title">📋 Instrucciones para JUGADORES</div>
            <small>
                <strong>PASO 1:</strong> Añade tu nombre arriba<br>
                <strong>PASO 2:</strong> Ve a la pestaña "Mis Apuestas" y selecciona tu nombre<br>
                <strong>PASO 3:</strong> Rellena todos tus pronósticos<br>
                <strong>PASO 4:</strong> Cuando termines, pulsa "📤 EXPORTAR MIS APUESTAS" y envíale el archivo al administrador<br>
                <strong>PASO 5:</strong> Durante el mundial, ve a "Resultados en vivo" y marca los resultados reales para ver tus puntos<br><br>
                📌 <strong>Consulta el "Sistema de Puntuación" para saber cómo se ganan los puntos</strong>
            </small>
        </div>
    </div>

    <!-- PANEL APUESTAS -->
    <div id="panel-apuestas" class="panel">
        <div id="selectorJugadorApuestas" class="jugador-selector"></div>
        <div id="puntajeVivo" class="puntaje-vivo" style="display:none">
            🏆 <strong>TUS PUNTOS ACTUALES:</strong> <span id="puntosEnVivo">0</span> pts
        </div>
        <div id="lockedBanner" class="card" style="background:#e8454520;border-color:var(--red);display:none">
            🔒 <strong>APUESTAS CERRADAS</strong> - No puedes modificar nada.
        </div>
        
        <div class="card">
            <div class="card-title">🗓 FASE DE GRUPOS - 1X2 (3 pts por acierto)</div>
            <div id="gruposContent"></div>
            <div id="progresoGrupos"></div>
        </div>

        <div class="card">
            <div class="card-title">📋 CLASIFICACIÓN DE GRUPOS (2 pts por equipo acertado)</div>
            <div id="clasifContent"></div>
        </div>

        <div class="card">
            <div class="card-title">🔄 MEJORES TERCEROS (elige 8 - 2 pts por acierto)</div>
            <div id="tercerosContent"></div>
        </div>

        <div class="card">
            <div class="card-title">⭐ APUESTAS ESPECIALES</div>
            <div id="especialesContent"></div>
        </div>

        <div class="flex-row" style="gap:12px; margin-top:20px">
            <button class="btn" onclick="exportarApuestas()">📤 EXPORTAR MIS APUESTAS</button>
            <button class="btn btn-danger" onclick="cerrarLocalmente()">🔒 CERRAR LOCALMENTE</button>
        </div>
    </div>

    <!-- PANEL RESULTADOS EN VIVO -->
    <div id="panel-resultados" class="panel">
        <div class="card">
            <div class="card-title">🎯 RESULTADOS REALES DEL MUNDIAL</div>
            <p><small>Introduce los resultados de cada partido. La clasificación de grupos y los mejores terceros se calculan automáticamente.</small></p>
            <div style="max-height:550px; overflow-y:auto; padding-right:8px">
                <div id="resultadosVivoContent"></div>
            </div>
        </div>
        
        <div class="card">
            <div class="card-title">📊 CLASIFICACIÓN AUTOMÁTICA DE GRUPOS</div>
            <div id="clasificacionAutomatica"></div>
        </div>
        
        <div class="card">
            <div class="card-title">🔄 MEJORES TERCEROS (calculados automáticamente)</div>
            <div id="mejoresTercerosAuto"></div>
        </div>
        
        <div class="card">
            <div class="card-title">⭐ ESPECIALES REALES</div>
            <div class="flex-row">
                <input id="realCampeonVivo" class="admin-input" placeholder="Campeón real" style="flex:1">
                <input id="realGoleadorVivo" class="admin-input" placeholder="Goleador real" style="flex:1">
                <input id="realPorteroVivo" class="admin-input" placeholder="Portero real" style="flex:1">
            </div>
            <button class="btn-secondary" onclick="guardarEspecialesRealesVivo()" style="margin-top:12px">💾 Guardar especiales</button>
        </div>
    </div>

    <!-- PANEL SISTEMA DE PUNTUACIÓN (NUEVO) -->
    <div id="panel-puntuacion" class="panel">
        <div class="card">
            <div class="card-title">📋 SISTEMA DE PUNTUACIÓN</div>
            <p><small>Así se calculan los puntos en la quiniela. ¡Acierta y suma!</small></p>
            
            <table class="puntuacion-tabla" style="margin-top: 20px;">
                <thead>
                    <tr>
                        <th>Categoría</th>
                        <th>Detalle</th>
                        <th>Puntos</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>🏆 Fase de Grupos</strong></td>
                        <td>Acertar el resultado exacto (1, X o 2) de cualquier partido de grupos</td>
                        <td><span class="punto-destacado">3 pts</span> por acierto</td>
                    </tr>
                    <tr>
                        <td><strong>📋 Clasificación de Grupos</strong></td>
                        <td>Acertar qué equipos quedan 1º y 2º de cada grupo (12 grupos)</td>
                        <td><span class="punto-destacado">2 pts</span> por equipo acertado</td>
                    </tr>
                    <tr>
                        <td><strong>🔄 Mejores Terceros</strong></td>
                        <td>Acertar cuáles de los 12 equipos que quedan 3º pasan a octavos (pasan los 8 mejores)</td>
                        <td><span class="punto-destacado">2 pts</span> por tercero acertado</td>
                    </tr>
                    <tr style="background: rgba(0,212,170,0.05);">
                        <td><strong>🏆 Campeón</strong></td>
                        <td>Acertar qué selección gana el Mundial</td>
                        <td><span class="punto-destacado">15 pts</span></td>
                    </tr>
                    <tr style="background: rgba(0,212,170,0.05);">
                        <td><strong>⚽ Máximo Goleador</strong></td>
                        <td>Acertar qué jugador marca más goles en todo el torneo</td>
                        <td><span class="punto-destacado">10 pts</span></td>
                    </tr>
                    <tr style="background: rgba(0,212,170,0.05);">
                        <td><strong>🧤 Portero Menos Goleado</strong></td>
                        <td>Acertar qué portero recibe menos goles (mínimo 3 partidos)</td>
                        <td><span class="punto-destacado">10 pts</span></td>
                    </tr>
                </tbody>
            </table>

            <div class="info-box" style="margin-top: 20px;">
                <strong>📌 EJEMPLO PRÁCTICO:</strong><br><br>
                • Un jugador acierta 40 partidos de grupos → <strong>120 puntos</strong><br>
                • Acierta 10 equipos clasificados de grupos → <strong>20 puntos</strong><br>
                • Acierta 5 mejores terceros → <strong>10 puntos</strong><br>
                • Acierta el campeón → <strong>15 puntos</strong><br>
                • Acierta el goleador → <strong>10 puntos</strong><br>
                • Acierta el portero → <strong>10 puntos</strong><br>
                • <strong>TOTAL: 185 puntos posibles</strong>
            </div>

            <div class="info-box" style="background: rgba(247,201,72,0.05); border-left-color: var(--accent2);">
                <strong>🎯 ¿EMPATE EN LA CLASIFICACIÓN?</strong><br>
                En caso de empate a puntos, el ganador se decide por:<br>
                1. Mayor número de aciertos en especiales (campeón, goleador, portero)<br>
                2. Mayor número de aciertos en la clasificación de grupos<br>
                3. Mayor número de aciertos en resultados de grupos (1X2)
            </div>
        </div>
    </div>

    <!-- PANEL ADMIN -->
    <div id="panel-admin" class="panel">
        <div class="card">
            <div class="card-title">📦 IMPORTAR APUESTAS DE JUGADORES</div>
            <input type="file" id="importarArchivo" accept=".json" class="file-input">
            <button class="btn" onclick="importarApuestas()">📂 Importar archivo</button>
        </div>
        
        <div class="card">
            <div class="card-title">📋 JUGADORES REGISTRADOS</div>
            <div id="listaJugadoresAdmin"></div>
            <button class="btn btn-danger" onclick="exportarTodosLosDatos()" style="background:var(--accent2);color:#000">💾 Backup completo</button>
            <button class="btn btn-blue" onclick="generarPDF()" style="margin-top:8px">📄 Generar PDF del Ranking</button>
        </div>
    </div>

    <!-- PANEL RANKING -->
    <div id="panel-ranking" class="panel">
        <div class="card">
            <div class="card-title">🏆 CLASIFICACIÓN GENERAL</div>
            <button class="btn-small" onclick="generarPDF()" style="background:var(--blue);margin-bottom:16px">📄 Exportar a PDF</button>
            <div id="rankingTabla"></div>
        </div>
    </div>
</div>

<script>
// ============================================================
// DATOS DEL MUNDIAL 2026
// ============================================================
const GRUPOS = {
    A:["🇲🇽 México","🇿🇦 Sudáfrica","🇰🇷 Corea del Sur","🇨🇿 Chequia"],
    B:["🇨🇦 Canadá","🇧🇦 Bosnia","🇶🇦 Qatar","🇨🇭 Suiza"],
    C:["🇧🇷 Brasil","🇲🇦 Marruecos","🇭🇹 Haití","🏴󠁧󠁢󠁳󠁣󠁴󠁿 Escocia"],
    D:["🇺🇸 USA","🇵🇾 Paraguay","🇦🇺 Australia","🇹🇷 Turquía"],
    E:["🇩🇪 Alemania","🇨🇼 Curazao","🇨🇮 Costa de Marfil","🇪🇨 Ecuador"],
    F:["🇳🇱 Países Bajos","🇯🇵 Japón","🇸🇪 Suecia","🇹🇳 Túnez"],
    G:["🇧🇪 Bélgica","🇪🇬 Egipto","🇮🇷 Irán","🇳🇿 Nueva Zelanda"],
    H:["🇪🇸 España","🇨🇻 Cabo Verde","🇸🇦 Arabia Saudí","🇺🇾 Uruguay"],
    I:["🇫🇷 Francia","🇸🇳 Senegal","🇮🇶 Irak","🇳🇴 Noruega"],
    J:["🇦🇷 Argentina","🇩🇿 Argelia","🇦🇹 Austria","🇯🇴 Jordania"],
    K:["🇵🇹 Portugal","🇨🇩 Congo DR","🇺🇿 Uzbekistán","🇨🇴 Colombia"],
    L:["🏴󠁧󠁢󠁥󠁮󠁧󠁿 Inglaterra","🇭🇷 Croacia","🇬🇭 Ghana","🇵🇦 Panamá"]
};
const TODOS_EQUIPOS = [...new Set(Object.values(GRUPOS).flat())].sort();

// Generar todos los partidos de grupos (72 partidos)
let PARTIDOS = [];
let idPartido = 0;
for(const [g, eqs] of Object.entries(GRUPOS)){
    for(let i=0;i<eqs.length;i++){
        for(let j=i+1;j<eqs.length;j++){
            PARTIDOS.push({id:idPartido++, grupo:g, local:eqs[i], visitante:eqs[j]});
        }
    }
}

// ============================================================
// FUNCIONES DE CÁLCULO AUTOMÁTICO
// ============================================================
function calcularClasificacionGrupos(){
    let puntosPorGrupo = {};
    for(const g of Object.keys(GRUPOS)){
        puntosPorGrupo[g] = {};
        for(const eq of GRUPOS[g]){
            puntosPorGrupo[g][eq] = { pts: 0 };
        }
    }
    for(const p of PARTIDOS){
        const resultado = resultadosReales.partidos[p.id];
        if(resultado === '1'){
            puntosPorGrupo[p.grupo][p.local].pts += 3;
        } else if(resultado === 'x'){
            puntosPorGrupo[p.grupo][p.local].pts += 1;
            puntosPorGrupo[p.grupo][p.visitante].pts += 1;
        } else if(resultado === '2'){
            puntosPorGrupo[p.grupo][p.visitante].pts += 3;
        }
    }
    let clasificacion = {};
    for(const g of Object.keys(GRUPOS)){
        const equipos = Object.entries(puntosPorGrupo[g]);
        equipos.sort((a,b) => b[1].pts - a[1].pts);
        clasificacion[g] = equipos.map(e => e[0]);
    }
    return clasificacion;
}

function calcularMejoresTerceros(){
    const clasificacion = calcularClasificacionGrupos();
    let terceros = [];
    for(const g of Object.keys(GRUPOS)){
        if(clasificacion[g].length >= 3 && clasificacion[g][2]){
            terceros.push(clasificacion[g][2]);
        }
    }
    return terceros.slice(0,8);
}

// ============================================================
// ESTADO DE LA APP
// ============================================================
let jugadores = [];
let apuestas = {};
let resultadosReales = {
    partidos: {},
    campeon: "",
    goleador: "",
    portero: ""
};
let jugadorActual = null;

function cargarDatos() {
    const datos = localStorage.getItem("quiniela_mundial_completa");
    if(datos){
        try{
            const data = JSON.parse(datos);
            jugadores = data.jugadores || [];
            apuestas = data.apuestas || {};
            resultadosReales = data.resultadosReales || { partidos:{}, campeon:"", goleador:"", portero:"" };
        }catch(e){}
    }
    if(jugadores.length && !jugadorActual) jugadorActual = jugadores[0].id;
}

function guardarDatos() {
    localStorage.setItem("quiniela_mundial_completa", JSON.stringify({ jugadores, apuestas, resultadosReales }));
}

function calcularPuntosJugador(pid){
    let pts = 0;
    const bets = apuestas[pid];
    if(!bets) return 0;
    
    for(const [partidoId, prono] of Object.entries(bets.grupos || {})){
        const real = resultadosReales.partidos[parseInt(partidoId)];
        if(real && prono === real) pts += 3;
    }
    
    const clasificacionReal = calcularClasificacionGrupos();
    for(const [g, eqs] of Object.entries(bets.clasif || {})){
        const reales = clasificacionReal[g] ? [clasificacionReal[g][0], clasificacionReal[g][1]] : [];
        eqs.forEach(eq => { if(reales.includes(eq)) pts += 2; });
    }
    
    const tercerosReales = calcularMejoresTerceros();
    (bets.terceros || []).forEach(eq => {
        if(tercerosReales.includes(eq)) pts += 2;
    });
    
    const esp = bets.especiales || {};
    if(esp.campeon && esp.campeon === resultadosReales.campeon) pts += 15;
    if(esp.goleador && esp.goleador === resultadosReales.goleador) pts += 10;
    if(esp.portero && esp.portero === resultadosReales.portero) pts += 10;
    
    return pts;
}

function mostrarPuntajeEnVivo(){
    if(jugadorActual){
        const pts = calcularPuntosJugador(jugadorActual);
        document.getElementById("puntosEnVivo").innerText = pts;
        document.getElementById("puntajeVivo").style.display = "block";
    }
}

// ============================================================
// JUGADORES
// ============================================================
function agregarJugador() {
    const input = document.getElementById("nuevoJugadorInput");
    const nombre = input.value.trim();
    if(!nombre) return;
    if(jugadores.find(j=>j.nombre.toLowerCase()===nombre.toLowerCase())){
        alert("Ya existe");
        return;
    }
    const id = "j_" + Date.now();
    jugadores.push({id, nombre});
    apuestas[id] = {
        grupos: {},
        clasif: {},
        terceros: [],
        especiales: {},
        cerradoLocal: false,
        importadoAdmin: false
    };
    input.value = "";
    guardarDatos();
    renderizarTodo();
}

function eliminarJugador(id){
    if(confirm("¿Eliminar?")){
        jugadores = jugadores.filter(j=>j.id !== id);
        delete apuestas[id];
        if(jugadorActual === id) jugadorActual = jugadores[0]?.id || null;
        guardarDatos();
        renderizarTodo();
    }
}

function cerrarLocalmente(){
    if(!jugadorActual) return;
    if(confirm("¿Cerrar tus apuestas? No podrás modificarlas más.")){
        apuestas[jugadorActual].cerradoLocal = true;
        guardarDatos();
        renderizarTodo();
    }
}

function cambiarJugador(id){
    jugadorActual = id;
    renderizarTodo();
    mostrarPuntajeEnVivo();
}

// ============================================================
// APUESTAS - GRUPOS 1X2
// ============================================================
function setPronosticoGrupo(partidoId, valor){
    if(!jugadorActual) return;
    if(apuestas[jugadorActual].cerradoLocal || apuestas[jugadorActual].importadoAdmin) return;
    apuestas[jugadorActual].grupos[partidoId] = valor;
    guardarDatos();
    renderGrupos();
    mostrarPuntajeEnVivo();
}

function renderGrupos(){
    const cont = document.getElementById("gruposContent");
    const cerrado = apuestas[jugadorActual]?.cerradoLocal || apuestas[jugadorActual]?.importadoAdmin;
    let html = "";
    let total = 0, rellenos = 0;
    for(const [g, eqs] of Object.entries(GRUPOS)){
        html += `<div class="grupo-titulo">Grupo ${g}</div>`;
        const partidosGrupo = PARTIDOS.filter(p => p.grupo === g);
        partidosGrupo.forEach(p => {
            total++;
            const prono = apuestas[jugadorActual]?.grupos[p.id] || "";
            if(prono) rellenos++;
            const real = resultadosReales.partidos[p.id];
            html += `<div class="partido">
                <div class="equipos">${p.local} vs ${p.visitante}</div>
                <div class="botones">
                    <button class="apuesta-btn ${prono==='1'?'selected-1':''}" onclick="setPronosticoGrupo(${p.id},'1')" ${cerrado?'disabled':''}>1</button>
                    <button class="apuesta-btn ${prono==='x'?'selected-x':''}" onclick="setPronosticoGrupo(${p.id},'x')" ${cerrado?'disabled':''}>X</button>
                    <button class="apuesta-btn ${prono==='2'?'selected-2':''}" onclick="setPronosticoGrupo(${p.id},'2')" ${cerrado?'disabled':''}>2</button>
                </div>
                ${real ? `<div class="resultado-real">Real: ${real}</div>` : ''}
            </div>`;
        });
    }
    cont.innerHTML = html;
    const pct = total ? Math.round(rellenos/total*100) : 0;
    document.getElementById("progresoGrupos").innerHTML = `<small>${rellenos}/${total} (${pct}%)</small><div style="background:#2a3650;height:4px;border-radius:2px;margin-top:4px"><div style="background:var(--accent);width:${pct}%;height:4px;border-radius:2px"></div></div>`;
}

