// ============================================================
// IMPORTAR/EXPORTAR
// ============================================================
function exportarApuestas(){
    if(!jugadorActual) return;
    const jugador = jugadores.find(j=>j.id===jugadorActual);
    const datos = {
        version: "1.0",
        fecha: new Date().toISOString(),
        jugador: { id: jugador.id, nombre: jugador.nombre },
        datos: apuestas[jugadorActual]
    };
    const blob = new Blob([JSON.stringify(datos,null,2)], {type:"application/json"});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `quiniela_${jugador.nombre}.json`;
    a.click();
    URL.revokeObjectURL(url);
}

function importarApuestas(){
    const file = document.getElementById("importarArchivo").files[0];
    if(!file) return;
    const reader = new FileReader();
    reader.onload = function(e){
        try{
            const data = JSON.parse(e.target.result);
            if(!data.jugador || !data.datos){
                alert("Archivo inválido");
                return;
            }
            let jugadorExistente = jugadores.find(j=>j.id === data.jugador.id);
            if(!jugadorExistente){
                jugadores.push({ id: data.jugador.id, nombre: data.jugador.nombre });
                apuestas[data.jugador.id] = data.datos;
                apuestas[data.jugador.id].importadoAdmin = true;
            } else {
                apuestas[data.jugador.id] = data.datos;
                apuestas[data.jugador.id].importadoAdmin = true;
            }
            guardarDatos();
            renderizarTodo();
            alert(`Apuestas de ${data.jugador.nombre} importadas correctamente`);
        } catch(err){
            alert("Error al leer el archivo");
        }
    };
    reader.readAsText(file);
}

function exportarTodosLosDatos(){
    const datos = { jugadores, apuestas, resultadosReales };
    const blob = new Blob([JSON.stringify(datos,null,2)], {type:"application/json"});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `quiniela_backup_${new Date().toISOString().slice(0,19)}.json`;
    a.click();
    URL.revokeObjectURL(url);
}

// ============================================================
// RANKING Y PDF
// ============================================================
function calcularRanking(){
    const ranking = jugadores.map(j => ({
        nombre: j.nombre,
        pts: calcularPuntosJugador(j.id)
    })).sort((a,b) => b.pts - a.pts);
    
    let html = `<table class="ranking-table">
        <thead><tr><th>#</th><th>Jugador</th><th>Puntos</th></thead>
        <tbody>`;
    ranking.forEach((j,i) => {
        html += `<tr><td style="padding:12px;">${i+1}º</td><td style="padding:12px;">${j.nombre}</td><td style="padding:12px;"><span class="pts-badge">${j.pts} pts</span></td></tr>`;
    });
    html += `</tbody></table>`;
    document.getElementById("rankingTabla").innerHTML = html;
    return ranking;
}

function generarPDF(){
    const ranking = calcularRanking();
    const fecha = new Date().toLocaleString();
    
    let htmlPDF = `
        <div style="font-family: Arial, sans-serif; padding: 20px;">
            <h1 style="color: #00d4aa; text-align: center;">⚽ MUNDIAL 2026</h1>
            <h2 style="text-align: center;">Clasificación de la Quiniela</h2>
            <p style="text-align: center; color: #666;">Fecha: ${fecha}</p>
            <hr>
            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
                <thead><tr style="background: #00d4aa; color: white;"><th style="padding: 10px;">Posición</th><th style="padding: 10px;">Jugador</th><th style="padding: 10px;">Puntos</th></tr></thead>
                <tbody>`;
    
    ranking.forEach((j,i) => {
        htmlPDF += `<tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 10px;">${i+1}º</td>
            <td style="padding: 10px;">${j.nombre}</td>
            <td style="padding: 10px; font-weight: bold;">${j.pts} pts</td>
        </tr>`;
    });
    
    htmlPDF += `
                </tbody>
            </table>
            <hr>
            <p style="text-align: center; font-size: 12px; color: #666; margin-top: 30px;">
                Quiniela generada automáticamente · Los puntos se actualizan con los resultados reales
            </p>
        </div>
    `;
    
    const opt = {
        margin: [0.5, 0.5, 0.5, 0.5],
        filename: `quiniela_ranking_${new Date().toISOString().slice(0,10)}.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, letterRendering: true },
        jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
    };
    
    const element = document.createElement('div');
    element.innerHTML = htmlPDF;
    document.body.appendChild(element);
    html2pdf().set(opt).from(element).save().then(() => {
        document.body.removeChild(element);
    });
}

