function setClasificacion(grupo, equipo, isChecked){
    if(!jugadorActual) return;
    if(apuestas[jugadorActual].cerradoLocal || apuestas[jugadorActual].importadoAdmin) return;
    let arr = apuestas[jugadorActual].clasif[grupo] || [];
    if(isChecked){
        if(arr.length < 2 && !arr.includes(equipo)) arr.push(equipo);
    }else{
        arr = arr.filter(e => e !== equipo);
    }
    apuestas[jugadorActual].clasif[grupo] = arr;
    guardarDatos();
    renderClasificacion();
    mostrarPuntajeEnVivo();
}

function renderClasificacion(){
    const cont = document.getElementById("clasifContent");
    const cerrado = apuestas[jugadorActual]?.cerradoLocal || apuestas[jugadorActual]?.importadoAdmin;
    let html = '<div class="grid-2">';
    for(const [g, eqs] of Object.entries(GRUPOS)){
        const seleccionados = apuestas[jugadorActual]?.clasif[g] || [];
        html += `<div class="card" style="padding:12px"><strong>Grupo ${g}</strong> (${seleccionados.length}/2)`;
        eqs.forEach(eq => {
            const checked = seleccionados.includes(eq);
            const disabled = cerrado || (!checked && seleccionados.length>=2);
            html += `<label class="chk-label" style="display:block;opacity:${disabled?0.5:1}">
                <input type="checkbox" ${checked?'checked':''} ${disabled?'disabled':''} onchange="setClasificacion('${g}','${eq.replace(/'/g,"\\'")}',this.checked)"> ${eq}
            </label>`;
        });
        html += `</div>`;
    }
    html += `</div>`;
    cont.innerHTML = html;
}

